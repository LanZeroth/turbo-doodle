{
  "manifest_version": 2,
  "name": "My Dummy Extension",
  "version": "1.0.0",
  "description": "A simple dummy extension for testing",
  
  "permissions": [
    "activeTab",
    "storage"
  ],
  
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Dummy Extension"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  
  "icons": {
    "48": "icon.png"
  }
}
